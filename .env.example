# =============================================================================
# Deep Learning RAG Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM PROVIDER — uncomment exactly one block
# -----------------------------------------------------------------------------

# --- Option 1: Groq (recommended — free tier, fast inference) ----------------
# Sign up at: https://console.groq.com
# Supported models: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Option 2: Ollama (fully local, no API key required) ---------------------
# Install from: https://ollama.com
# Pull a model first: ollama pull llama3.2
# Start Ollama before running the app: ollama serve
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Option 3: LM Studio (local GUI, OpenAI-compatible server) ---------------
# Install from: https://lmstudio.ai
# Load a model in LM Studio, then start the local server (port 1234)
# LLM_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model   # must match the model loaded in LM Studio

# -----------------------------------------------------------------------------
# EMBEDDINGS — controls how documents are embedded into ChromaDB
# -----------------------------------------------------------------------------
# local    = sentence-transformers (no API key, runs on CPU, slower first load)
# groq     = not supported for embeddings — falls back to local automatically
# openai   = requires OPENAI_API_KEY, costs money, very fast
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2   # fast and lightweight for local use
# EMBEDDING_MODEL=all-mpnet-base-v2 # higher quality, slower

# -----------------------------------------------------------------------------
# VECTOR STORE
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=deep_learning_corpus

# -----------------------------------------------------------------------------
# RETRIEVAL SETTINGS
# -----------------------------------------------------------------------------
RETRIEVAL_K=4                       # number of chunks to retrieve per query
SIMILARITY_THRESHOLD=0.3            # minimum score — below this = no match
MAX_CONTEXT_TOKENS=3000             # trim conversation history above this

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
APP_TITLE=Deep Learning Interview Prep Agent
CORPUS_DIR=./data/corpus
